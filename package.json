{
  "name": "aplikacja-treningowa",
  "version": "5.0.60",
  "description": "Aplikacja do śledzenia planów treningowych.",
  "main": "app.js",
  "private": true,
  "scripts": {
    "test": "node tests/run.js",
    "lint": "npm run lint:css && npm run lint:js",
    "lint:css": "stylelint \"*.css\" \"css/**/*.css\"",
    "lint:js": "npm run lint:js:eslint && npm run lint:js:syntax",
    "smoke": "npm run smoke:manifest && npm run smoke:assets",
    "test:ci": "npm run test && npm run lint && npm run smoke",
    "smoke:manifest": "node tests/smoke/manifest-check.js",
    "lint:js:eslint": "eslint . --max-warnings=0",
    "lint:js:syntax": "node tests/smoke/js-syntax-check.js",
    "smoke:assets": "node tests/smoke/asset-paths-check.js"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "jose": "^6.2.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "netlify-cli": "^12.14.0",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1"
  }
}
